{
  "name": "pashusetu",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "RUN_DB_TESTS=1 vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "qa:db:up": "bash scripts/qa-db.sh up",
    "qa:db:reset": "bash scripts/qa-db.sh reset",
    "qa:db:run": "bash scripts/qa-db.sh run",
    "qa:db:down": "bash scripts/qa-db.sh down",
    "br:coverage": "node scripts/check-br-coverage.mjs",
    "size": "size-limit",
    "lhci": "lhci autorun",
    "postinstall": "prisma generate",
    "grant-admin": "tsx scripts/grant-admin.ts",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-linux-x64": "1.3.2",
    "@img/sharp-linux-x64": "0.35.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@faker-js/faker": "^10.5.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "next-test-api-route-handler": "^5.0.5",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "prisma": "^7.8.0",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "tmp": ">=0.2.6"
    }
  }
