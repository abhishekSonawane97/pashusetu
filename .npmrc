# Flatten node_modules (npm-style) instead of pnpm's default isolated symlink layout.
# Required so sharp's native binary + libvips (@img/sharp-libvips-linux-x64) are plain
# top-level deps that Vercel's function file-tracing includes in the serverless bundle —
# otherwise the nested/symlinked .so is missed and image processing 500s on prod with
# "libvips-cpp.so: cannot open shared object file" (dev is unaffected). Safe: the app
# already builds under the stricter isolated layout, so hoisting only adds reachability.
node-linker=hoisted
