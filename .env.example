# PashuSetu environment variables — catalog per docs/09-backend/README.md §11.
# Copy to .env.local for local dev. NEVER commit real values.

# --- Database (Neon PostgreSQL, docs/07 §8) ---
DATABASE_URL=            # pooled connection string (-pooler host, pgbouncer=true)
DIRECT_URL=              # direct connection string — Prisma migrations only

# --- Firebase Admin (server; docs/12 §3) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=    # keep \n escaped when set via Vercel UI

# --- Firebase client config (public, NEXT_PUBLIC_*) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Dev/CI ONLY — set to 1 to bypass reCAPTCHA for registered Firebase test numbers
# (appVerificationDisabledForTesting). MUST be unset/absent in production.
NEXT_PUBLIC_FIREBASE_TEST_MODE=

# --- Cloudflare R2 (docs/09 §7, docs/12 §6) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=      # public image CDN base, e.g. https://img.pashusetu.in

# --- SMS (MSG91, docs/09 §8) ---
MSG91_AUTH_KEY=
MSG91_SENDER_ID=

# --- Observability (docs/13 §7) ---
SENTRY_DSN=

# --- Jobs (docs/09 §9) ---
CRON_SECRET=             # shared secret for /api/cron/* routes

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
