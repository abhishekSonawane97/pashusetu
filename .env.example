# PashuSetu environment variables — catalog per docs/09-backend/README.md §11.
# Copy to .env.local for local dev. NEVER commit real values.

# --- Database (Neon PostgreSQL, docs/07 §8) ---
DATABASE_URL=            # pooled connection string (-pooler host, pgbouncer=true)
DIRECT_URL=              # direct connection string — Prisma migrations only

# --- Firebase Admin (server; docs/12 §3) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=    # keep \n escaped when set via Vercel UI

# --- Firebase client config (public, NEXT_PUBLIC_*) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Dev/CI ONLY — set to 1 to bypass reCAPTCHA for registered Firebase test numbers
# (appVerificationDisabledForTesting). MUST be unset/absent in production.
NEXT_PUBLIC_FIREBASE_TEST_MODE=

# --- Object storage (S3-compatible: R2 / Supabase / MinIO — docs/09 §7, docs/12 §6) ---
# The app is provider-agnostic; only these env vars change between providers.
# R2_BUCKET is a PREFIX → the code uses "<R2_BUCKET>-uploads" (private) + "<R2_BUCKET>-public".
R2_ENDPOINT=             # S3 API endpoint. R2: https://<acct>.r2.cloudflarestorage.com
                         # Supabase: https://<ref>.storage.supabase.co/storage/v1/s3
R2_ACCOUNT_ID=           # R2 only (derives the endpoint if R2_ENDPOINT unset)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=               # R2: leave blank (defaults to 'auto'). Supabase/AWS: the real region, e.g. ap-south-1
R2_FORCE_PATH_STYLE=     # '1' for Supabase/MinIO (path-style); leave blank for R2 (vhost)
R2_BUCKET=               # prefix, e.g. pashusetu
R2_PUBLIC_BASE_URL=      # bare public base (code appends /listings/...). R2 custom domain: https://img.pashusetu.in
                         # Supabase: https://<ref>.supabase.co/storage/v1/object/public/<R2_BUCKET>-public

# --- SMS (MSG91, docs/09 §8) ---
MSG91_AUTH_KEY=
MSG91_SENDER_ID=

# --- Observability (docs/13 §7, PS-005) ---
# Both unset in dev → the error reporter is a no-op. Same DSN value for both;
# NEXT_PUBLIC_ is the browser-safe client key, SENTRY_DSN is the server one.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=       # optional; defaults to VERCEL_ENV / NODE_ENV
SENTRY_RELEASE=           # optional; defaults to VERCEL_GIT_COMMIT_SHA

# --- Jobs (docs/09 §9) ---
CRON_SECRET=             # shared secret for /api/cron/* routes

# --- App ---
# Dev: localhost. Prod (Vercel): https://pashusetu.online — drives canonical/OG/sitemap.
NEXT_PUBLIC_APP_URL=http://localhost:3000
